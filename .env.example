# ============================================
# LlamaIndex RAG 应用 - 环境变量配置示例
# ============================================

# 复制此文件为 .env 并填写实际配置值
# 所有配置项均有默认值，可根据需要修改

# ------------------------------------------------
# 安全配置
# ------------------------------------------------
SECRET_KEY=your-secret-key-here
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"

# ------------------------------------------------
# 百度千帆 API 配置（使用 qianfan 模式时必填）
# ------------------------------------------------
QIANFAN_API_KEY=your-qianfan-api-key
QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2

# ------------------------------------------------
# 模型配置
# ------------------------------------------------
# 模型类型: qianfan / ollama / hybrid
MODEL_TYPE=hybrid

# 千帆模型名称
MODEL_NAME=glm-5.1

# Ollama 模型配置（使用 ollama/hybrid 模式时）
OLLAMA_MODEL_NAME=qwen2:0.5b
OLLAMA_EMBEDDING_MODEL=llama3.1:8b

# HuggingFace 嵌入模型（使用 hybrid 模式时）
HF_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ------------------------------------------------
# 文档处理配置
# ------------------------------------------------
CHUNK_SIZE=1024
CHUNK_OVERLAP=200

# ------------------------------------------------
# LLM 生成配置
# ------------------------------------------------
TEMPERATURE=0.7
MAX_TOKENS=1000

# ------------------------------------------------
# 文件上传配置
# ------------------------------------------------
UPLOAD_FOLDER=static/uploads
ALLOWED_EXTENSIONS=pdf,docx,md,txt
MAX_FILE_SIZE=52428800  # 50MB

# ------------------------------------------------
# 向量存储配置
# ------------------------------------------------
VECTOR_STORE_PATH=vector_store

# ------------------------------------------------
# Flask 应用配置
# ------------------------------------------------
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# ------------------------------------------------
# 日志配置
# ------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=app.log
